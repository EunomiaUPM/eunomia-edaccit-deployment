{
  "authentication": {
    "type": "OAUTH2",
    "grantType": {
      "type": "PASSWORD",
      "username": "{{__USER_NAME__}}",
      "password": {
        "type": "PLAIN",
        "content": "{{__USER_PASS__}}"
      }
    },
    "tokenUrl": "{{__TOKEN_URL__}}",
    "clientId": "{{__CLIENT_ID__}}",
    "clientSecret": { "type": "PLAIN", "content": "{{__CLIENT_SECRET__}}" },
    "scopes": [],
    "onTokenExpire": "REFRESH_OR_REFETCH"
  },
  "interaction": {
    "mode": "PUSH",
    "subscribe": {
      "protocol": "HTTP",
      "urlTemplate": "{{__SUB_URL__}}",
      "method": "POST",
      "headers": {},
      "bodyTemplate": "{\"url\": \"{{__SYS_OWN_URL_DOCKER__}}{{__RUNTIME_INGRESS__}}\", \"event_type\": \"hotel_waste_generated\"}"
    },
    "unsubscribe": {
      "protocol": "HTTP",
      "urlTemplate": "{{__UNSUB_URL__}}/{{__RUNTIME_JSON_{.subscription.data.ID}__}}",
      "method": "POST",
      "headers": {},
      "bodyTemplate": "{}"
    }
  },
  "parameters": [
    {
      "paramType": "STRING",
      "name": "SUB_URL",
      "title": "Subscription URL",
      "required": true
    },
    {
      "paramType": "STRING",
      "name": "UNSUB_URL",
      "title": "Unsubscription URL",
      "required": true
    },
    {
      "paramType": "STRING",
      "name": "USER_NAME",
      "title": "User Name",
      "required": true
    },
    {
      "paramType": "STRING",
      "name": "USER_PASS",
      "title": "User Password",
      "required": true
    },
    {
      "paramType": "STRING",
      "name": "TOKEN_URL",
      "title": "Token URL",
      "required": true
    },
    {
      "paramType": "STRING",
      "name": "CLIENT_ID",
      "title": "Client ID",
      "required": true
    },
    {
      "paramType": "STRING",
      "name": "CLIENT_SECRET",
      "title": "Client Secret",
      "required": true
    }
  ]
}
