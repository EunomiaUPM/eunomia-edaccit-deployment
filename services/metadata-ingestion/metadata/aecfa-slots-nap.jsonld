      "dct:identifier": "aecfa-slots",
      "dct:title": {
        "@value": "AECFA Slots – Datos de vuelos y slots aeroportuarios",
        "@language": "es"
      },

      "dct:description": {
        "@value": "Conjunto de datos de slots de vuelos publicados por AECFA a través del Punto de Acceso Nacional de Transporte (NAP). Incluye información sobre llegadas y salidas de vuelos en aeropuertos nacionales. El dataset se publica en dos formatos: GTFS con vuelos nacionales y TXT con todos los slots de llegadas y salidas de aeropuertos nacionales.",
        "@language": "es"
      },

      "dct:publisher": {
        "@id": "urn:org:ministerio-transportes"
      },

