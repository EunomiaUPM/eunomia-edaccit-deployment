    {
      "@id": "urn:dataset:aemet-valores-climatologicos-diarios-estacion",
      "@type": "dcat:Dataset",
      "dct:identifier": "aemet-valores-climatologicos-diarios-estacion",
      "dct:title": {
        "@value": "Valores climatológicos diarios por estación meteorológica (AEMET)",
        "@language": "es"
      },
      "dct:description": {
        "@value": "Conjunto de datos de observaciones climatológicas diarias por estación meteorológica publicado por AEMET. Cada registro se referencia por fecha de observación e identificador de estación e incluye variables como temperatura media, mínima y máxima, precipitación, dirección y velocidad media del viento, racha máxima, insolación, presión atmosférica y humedad relativa, junto con las horas asociadas a determinados extremos. También incorpora metadatos de estación como indicativo, nombre, provincia y altitud. El acceso se realiza a través de AEMET OpenData mediante la operación de valores climatológicos diarios y requiere API key.",
        "@language": "es"
      },
      "dct:language": [
        {
          "@id": "http://publications.europa.eu/resource/authority/language/SPA"
        }
      ],
