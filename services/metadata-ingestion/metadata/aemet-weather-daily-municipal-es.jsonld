    {
      "@id": "urn:dataset:aemet-weather-daily-municipal-es",
      "@type": "dcat:Dataset",
      "dct:identifier": "aemet-weather-daily-municipal-es",
      "dct:title": {
        "@value": "Predicción meteorológica diaria por municipio en España (fuente AEMET)",
        "@language": "es"
      },
      "dct:description": {
        "@value": "Dataset de predicción meteorológica diaria por municipio en España. El recurso es ofrecido por Esri España y la información meteorológica procede de la Agencia Estatal de Meteorología (AEMET). Se actualiza diariamente a las 09:15 GMT mediante un procedimiento automatizado. El servicio cubre más de 1.700 municipios distribuidos de forma uniforme por el territorio nacional y representa cada municipio mediante una entidad puntual correspondiente a su centroide. Incluye variables como probabilidad de precipitación, cota de nieve, estado y descripción del cielo, racha máxima, temperatura máxima y mínima, sensación térmica máxima y mínima, humedad relativa máxima y mínima, velocidad y dirección del viento e índice UV máximo. El sistema de coordenadas utilizado es WGS84 Web Mercator. La información se ofrece con fines de demostración y no se permite su uso en entornos productivos según las condiciones indicadas por el proveedor.",
        "@language": "es"
      },
      "dct:language": [
        {
          "@id": "http://publications.europa.eu/resource/authority/language/SPA"
        }
      ],
