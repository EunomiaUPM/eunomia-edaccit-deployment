      "@type": "dcat:Dataset",
      "dct:identifier": "espana-aeropuertos-trafico-civil-2016",

      "dct:title": {
        "@value": "España – Aeropuertos abiertos al tráfico civil (2016)",
        "@language": "es"
      },

      "dct:description": {
        "@value": "Mapa temático del Atlas Nacional de España (ANE) que representa los aeropuertos abiertos al tráfico civil en España en 2016. El producto cartográfico tiene escala 1:6.500.000 y se distribuye en formatos SHAPE, PDF y JPG. Los datos utilizan sistemas de referencia geodésicos ETRS89 y REGCAN95 en España y proyecciones cartográficas como Lambert y Winkel III.",
        "@language": "es"
      },

