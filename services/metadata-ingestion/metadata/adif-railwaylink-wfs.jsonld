    {
      "@id": "urn:dataset:adif-tramificacion-comun-railwaylink",
      "@type": "dcat:Dataset",
      "dct:identifier": "adif-tramificacion-comun-railwaylink",
      "dct:title": {
        "@value": "Tramificación Común de ADIF – RailwayLink (INSPIRE/WFS)",
        "@language": "es"
      },
      "dct:description": {
        "@value": "Conjunto de datos geográficos de carácter público sobre la Tramificación Común de ADIF accesible mediante un servicio WFS conforme a OGC WFS 1.1.0 y 2.0.0. El recurso permite el acceso, consulta, localización y descarga de información geográfica de la infraestructura ferroviaria generada en el marco del proyecto IDEADIF. En este caso se describe la capa INSPIRE tn-ra:RailwayLink, con geometrías lineales de eje, identificadores INSPIRE, nodos inicial y final, fechas de validez y geometría en GML. La actualización de la información del servicio es trimestral. La versión indicada en la ficha es Julio 2025 (tercer trimestre).",
        "@language": "es"
      },
      "dct:language": [
        {
          "@id": "http://publications.europa.eu/resource/authority/language/SPA"
        }
