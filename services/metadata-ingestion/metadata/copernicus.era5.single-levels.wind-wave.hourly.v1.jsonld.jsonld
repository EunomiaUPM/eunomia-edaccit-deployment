    {
      "@id": "urn:dataset:copernicus-era5-single-levels-u10-v10-hourly-global-subset-v1",
      "@type": "dcat:Dataset",
      "dct:identifier": "copernicus-era5-single-levels-u10-v10-hourly-global-subset-v1",
      "dct:title": {
        "@value": "ERA5 hourly single levels subset – 10 m wind components (NetCDF extract)",
        "@language": "en"
      },
      "dct:description": {
        "@value": "Subset extract derived from the Copernicus Climate Data Store dataset 'ERA5 hourly data on single levels from 1940 to present'. This NetCDF file contains hourly global reanalysis data for the 10 metre U wind component and the 10 metre V wind component on a regular latitude-longitude grid with 0.25 degree spacing. The extract covers the period from 2026-02-01T00:00:00Z to 2026-02-03T23:00:00Z. The parent ERA5 dataset is part of the fifth generation ECMWF reanalysis distributed through the Copernicus Climate Data Store.",
        "@language": "en"
      },
      "dct:language": [
        {
          "@id": "http://publications.europa.eu/resource/authority/language/ENG"
        }
      ],
      "dct:publisher": {
        "@id": "urn:org:copernicus-c3s"
      },
