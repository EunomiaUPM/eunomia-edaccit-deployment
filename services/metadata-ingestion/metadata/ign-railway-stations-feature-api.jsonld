    {
      "@id": "urn:dataset:ign-red-ferrocarriles-estaciones",
      "@type": "dcat:Dataset",
      "dct:identifier": "ign-red-ferrocarriles-estaciones",
      "dct:title": {
        "@value": "Red de ferrocarriles de España – Estaciones",
        "@language": "es"
      },
      "dct:description": {
        "@value": "Capa de entidades de estaciones de la Red de ferrocarriles de España, basada en datos del Instituto Geográfico Nacional. Forma parte de una base de datos de la red intermodal de transporte, tridimensional, lineal, continua y con topología implícita, que contiene las infraestructuras y conexiones de la red de transporte por ferrocarril en España. La información tiene ámbito nacional. En la capa Estaciones las geometrías son puntuales y se incluyen campos como fecha_alta, cod_est, estadofis, estadofisd, id_estfc, n_andenes, nombre, tipo_estfc, tipo_estfd, tipo_uso y tipo_usod. La ficha indica que la fecha de última actualización de los datos por la fuente oficial es 2024-05-27 y la fecha de descarga y publicación en ArcGIS Online es 2024-06-14.",
        "@language": "es"
      },
