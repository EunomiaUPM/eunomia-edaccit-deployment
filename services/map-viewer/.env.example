# ArcGIS credentials — used ONLY by the backend to call generateToken.
# These values never reach the browser.
ARCGIS_PORTAL_URL=https://edaccit.esrilab.es/portal
ARCGIS_USERNAME=
ARCGIS_PASSWORD=

# Token lifetime in minutes (default: 120)
ARCGIS_TOKEN_EXPIRY=120

# Set to "false" if ESRILab uses a self-signed TLS certificate (default: true)
ARCGIS_VERIFY_SSL=true

# Comma-separated allowed CORS origins.
# Include the Vite dev server when developing locally.
ALLOWED_ORIGINS=http://localhost:5173
