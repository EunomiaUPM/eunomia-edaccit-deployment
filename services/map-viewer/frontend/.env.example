# Authentication mode:
#   "direct"           → SDK hits ArcGIS directly; FastAPI proxies the token (dev).
#   "eunomia-consumer" → Proxy URL is entered at runtime in the GUI; the proxy injects the token.
#   "eunomia"          → Legacy: Bearer token injected by the frontend via Consumer Eunomia session.
VITE_AUTH_MODE=direct

# Base URL of the upstream ArcGIS REST endpoint.
# direct / eunomia-consumer → ESRILab server URL.
# eunomia (legacy)          → Consumer Eunomia transfer mount point.
VITE_ARCGIS_BASE_URL=https://edaccit.esrilab.es/server

# (eunomia legacy only) Consumer Eunomia base URL for session auth.
VITE_EUNOMIA_CONSUMER_URL=
