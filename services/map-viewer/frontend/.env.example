# Authentication mode: "direct" (dev, token via FastAPI proxy) or "eunomia" (pilot)
VITE_AUTH_MODE=direct

# Base URL of the ArcGIS REST endpoint the SDK should talk to.
# direct mode  → the ArcGIS Server on ESRILab
# eunomia mode → the Consumer Eunomia transfer mount point
VITE_ARCGIS_BASE_URL=https://edaccit.esrilab.es/server

# (eunomia mode only) Consumer Eunomia base URL for session auth.
VITE_EUNOMIA_CONSUMER_URL=
